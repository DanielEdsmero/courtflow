# Copy to .env.local and fill in from Supabase → Project Settings → API.
# Both values are safe to expose in the browser bundle: the anon key is designed
# to be public and Row Level Security is what protects your data.
# NEVER put the service_role key here — it bypasses RLS entirely.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
